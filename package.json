{
  "name": "animecix-v2",
  "productName": "AnimeciX",
  "version": "0.1.1",
  "description": "Electron desktop app for AnimeciX — anime streaming, downloading, and offline playback",
  "main": ".vite/build/main.js",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/CaptainSP/animecix-dekstop-2.git"
  },
  "build": {
    "publish": [
      {
        "provider": "github",
        "owner": "CaptainSP",
        "repo": "animecix-dekstop-2"
      }
    ]
  },
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "pretest": "npm rebuild better-sqlite3 2>/dev/null || true",
    "test": "vitest run --reporter=dot",
    "build:player": "vite build --config vite.player.config.mts",
    "build:library": "vite build --config vite.library.config.mts",
    "postinstall": "npx @electron/rebuild -f -w better-sqlite3",
    "verify-tag": "node scripts/verify-tag.mjs",
    "generate-update-manifest": "node scripts/generate-update-manifest.mjs"
  },
  "keywords": [
    "electron",
    "anime",
    "streaming",
    "desktop",
    "video-player",
    "offline",
    "hls"
  ],
  "author": {
    "name": "CaptainSP",
    "email": "19982002ke@gmail.com"
  },
  "license": "MIT",
  "overrides": {
    "@electron/universal": ">=2.0.3"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "electron": "41.2.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@vidstack/react": "^1.12.13",
    "@xhayper/discord-rpc": "^1.3.3",
    "abp-filter-parser": "^0.2.0",
    "better-sqlite3": "^12.8.0",
    "bufferutil": "^4.1.0",
    "electron-log": "^5.2.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.8.3",
    "hls.js": "^1.6.15",
    "jassub": "^2.4.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
